{
  "memoryHome": ".aipc-work-memory",
  "date": "2026-06-08",
  "localMarkdownDirs": [
    {
      "path": "notes",
      "mode": "all",
      "files": [],
      "enabled": true
    }
  ],
  "obsidianVaults": [
    {
      "path": "/absolute/path/to/your/ObsidianVault",
      "mode": "modifiedToday",
      "files": [],
      "timezone": "Asia/Shanghai",
      "enabled": false
    }
  ],
  "links": [
    {
      "url": "https://example.com/article",
      "title": "今天看的文章",
      "summary": "这里放用户明确确认要进入今日整理的文章摘要或手动摘录。",
      "enabled": false
    }
  ],
  "dingtalk": {
    "enabled": false,
    "cli": "../../../tools/dws/dws",
    "documents": [
      {
        "nodeId": "<DINGTALK_DOC_NODE_ID_OR_URL>",
        "enabled": false
      }
    ],
    "sheets": [
      {
        "nodeId": "<DINGTALK_SHEET_NODE_ID_OR_URL>",
        "range": "A1:Z80",
        "enabled": false
      }
    ],
    "calendar": {
      "enabled": false,
      "calendarId": "primary",
      "start": "2026-06-08T00:00:00+08:00",
      "end": "2026-06-09T00:00:00+08:00"
    },
    "todos": {
      "enabled": false,
      "size": 20
    }
  },
  "feishu": {
    "enabled": false,
    "cli": "lark-cli",
    "agenda": true,
    "taskList": true,
    "docTokens": [],
    "minutesTokens": []
  },
  "outputs": {
    "wikiContext": "out/wiki_context.md",
    "dailyContext": "out/daily_context.md",
    "dailyMarkdown": "out/daily_memory.md"
  }
}
